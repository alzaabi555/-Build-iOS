<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root" android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:gravity="top" android:layoutDirection="rtl"
    android:paddingStart="12dp" android:paddingEnd="12dp" android:paddingTop="10dp" android:paddingBottom="9dp"
    android:background="@drawable/rased_schedule_widget_bg">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical" android:layoutDirection="rtl"
        android:layout_marginBottom="8dp">
        <TextView android:id="@+id/widget_logo_text" android:layout_width="32dp" android:layout_height="32dp"
            android:gravity="center" android:text="ر" android:textColor="#FFFFFF" android:textStyle="bold"
            android:textSize="16sp" android:background="@drawable/rased_schedule_day_chip_bg" android:layout_marginEnd="10dp" />
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
            <TextView android:id="@+id/widget_title" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="راصد" android:textColor="#163A5F" android:textSize="15sp" android:textStyle="bold" android:maxLines="1" />
            <TextView android:id="@+id/widget_subtitle" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="جدول الحصص" android:textColor="#5B7893" android:textSize="10sp" android:maxLines="1" />
            <TextView android:id="@+id/widget_updated" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="آخر تحديث من راصد" android:textColor="#8CA0B3" android:textSize="8sp" android:maxLines="1" />
        </LinearLayout>
        <TextView android:id="@+id/widget_today" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="اليوم" android:textColor="#FFFFFF" android:textSize="10sp" android:textStyle="bold"
            android:paddingStart="11dp" android:paddingEnd="11dp" android:paddingTop="5dp" android:paddingBottom="5dp"
            android:background="@drawable/rased_schedule_day_chip_bg" android:maxLines="1" />
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"
        android:orientation="horizontal" android:baselineAligned="false" android:gravity="center_vertical"
        android:layoutDirection="rtl">

        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:orientation="horizontal" android:gravity="center_vertical" android:layoutDirection="rtl"
            android:paddingStart="9dp" android:paddingEnd="9dp" android:paddingTop="7dp" android:paddingBottom="7dp"
            android:background="@drawable/rased_schedule_current_period_bg" android:layout_marginStart="4dp">
            <TextView
                android:layout_width="4dp"
                android:layout_height="match_parent"
                android:minHeight="72dp"
                android:text=""
                android:background="#8EC5F4"
                android:layout_marginEnd="8dp" />
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                <TextView android:id="@+id/widget_current_label" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="الحصة الآن" android:textColor="#2E6388" android:textSize="9sp" android:textStyle="bold" android:maxLines="1" />
                <TextView android:id="@+id/widget_current_class" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="-" android:textColor="#163A5F" android:textSize="17sp" android:textStyle="bold" android:maxLines="1" android:ellipsize="end" />
                <TextView android:id="@+id/widget_current_subject" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="" android:textColor="#5B7893" android:textSize="10sp" android:maxLines="1" android:ellipsize="end" />
                <TextView android:id="@+id/widget_current_time" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="" android:textColor="#245D82" android:textSize="10sp" android:textStyle="bold" android:maxLines="1"
                    android:ellipsize="end" android:layoutDirection="ltr" android:textDirection="ltr" android:gravity="start" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:orientation="horizontal" android:gravity="center_vertical" android:layoutDirection="rtl"
            android:paddingStart="9dp" android:paddingEnd="9dp" android:paddingTop="7dp" android:paddingBottom="7dp"
            android:background="@drawable/rased_schedule_next_period_bg" android:layout_marginEnd="4dp">
            <TextView
                android:layout_width="4dp"
                android:layout_height="match_parent"
                android:minHeight="72dp"
                android:text=""
                android:background="#B7D8F5"
                android:layout_marginEnd="8dp" />
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                <TextView android:id="@+id/widget_next_label" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="القادمة" android:textColor="#50748F" android:textSize="9sp" android:textStyle="bold" android:maxLines="1" />
                <TextView android:id="@+id/widget_next_class" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="-" android:textColor="#163A5F" android:textSize="17sp" android:textStyle="bold" android:maxLines="1" android:ellipsize="end" />
                <TextView android:id="@+id/widget_next_subject" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="" android:textColor="#6B8297" android:textSize="10sp" android:maxLines="1" android:ellipsize="end" />
                <TextView android:id="@+id/widget_next_time" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="" android:textColor="#245D82" android:textSize="10sp" android:textStyle="bold" android:maxLines="1"
                    android:ellipsize="end" android:layoutDirection="ltr" android:textDirection="ltr" android:gravity="start" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <TextView android:id="@+id/widget_attendance_tip" android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="تذكير: تسجيل الحضور والغياب مبكرًا يختصر وقت المتابعة."
        android:textColor="#6F879C" android:textSize="8sp" android:gravity="center" android:maxLines="1"
        android:ellipsize="end" android:layout_marginTop="6dp" android:layout_marginBottom="1dp" />
</LinearLayout>
