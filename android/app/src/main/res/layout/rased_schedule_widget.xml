<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@drawable/rased_schedule_widget_bg">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <ImageView
            android:id="@+id/widget_icon"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:src="@ight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/widget_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="راصد"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:maxLines="1" />

            <TextView
                android:id="@+id/widget_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="جدول الحصص"
                android:textColor="#C7D2FE"
                android:textSize="10sp"
                android:maxLines="1" />
        </LinearLayout>

        <TextView
            android:id="@+id/widget_today"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="اليوم"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:textStyle="bold"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:background="@drawable/rased_schedule_day_chip_bg"
            android:maxLines="1" />

    </LinearLayout>

    <!-- Current and next periods horizontally -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:baselineAligned="false">

        <!-- Current period -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="9dp"
            android:background="@drawable/rased_schedule_current_period_bg"
            android:layout_marginEnd="5dp">

            <TextView
                android:id="@+id/widget_current_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="الحصة الآن"
                android:textColor="#E0F2FE"
                android:textSize="10sp"
                android:textStyle="bold"
                android:maxLines="1" />

            <TextView
                android:id="@+id/widget_current_class"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="7/1"
                android:textColor="#FFFFFF"
                android:textSize="17sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/widget_current_subject"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="المادة"
                android:textColor="#BFDBFE"
                android:textSize="9sp"
                android:maxLines="1"
                android:layout_marginTop="1dp" />

            <TextView
                android:id="@+id/widget_current_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="08:00 - 08:45"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:layout_marginTop="4dp" />

        </LinearLayout>

        <!-- Next period -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="9dp"
            android:background="@drawable/rased_schedule_next_period_bg"
            android:layout_marginStart="5dp">

            <TextView
                android:id="@+id/widget_next_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="القادمة"
                android:textColor="#DBEAFE"
                android:textSize="10sp"
                android:textStyle="bold"
                android:maxLines="1" />

            <TextView
                android:id="@+id/widget_next_class"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="8/2"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/widget_next_subject"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="المادة"
                android:textColor="#BFDBFE"
                android:textSize="9sp"
                android:maxLines="1"
                android:layout_marginTop="1dp" />

            <TextView
                android:id="@+id/widget_next_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="09:00 - 09:45"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:layout_marginTop="4dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- Footer -->
    <TextView
        android:id="@+id/widget_updated"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="آخر تحديث من راصد"
        android:textColor="#C7D2FE"
        android:textSize="9sp"
        android:gravity="center"
        android:maxLines="1"
        android:layout_marginTop="7dp" />

</LinearLayout>
