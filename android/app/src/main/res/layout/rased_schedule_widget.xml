<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:layoutDirection="rtl"
    android:gravity="top"
    android:paddingStart="14dp"
    android:paddingEnd="14dp"
    android:paddingTop="12dp"
    android:paddingBottom="10dp"
    android:background="@drawable/rased_schedule_widget_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layoutDirection="rtl">

        <TextView
            android:id="@+id/widget_logo_text"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:gravity="center"
            android:text="ر"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="18sp"
            android:background="@drawable/rased_schedule_day_chip_bg"
            android:layout_marginEnd="10dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView android:id="@+id/widget_title" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="راصد" android:textColor="#173B5F" android:textSize="17sp" android:textStyle="bold" android:maxLines="1" />
            <TextView android:id="@+id/widget_subtitle" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="جدول الحصص" android:textColor="#607D96" android:textSize="10sp" android:maxLines="1" />
            <TextView android:id="@+id/widget_updated" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="آخر تحديث من راصد" android:textColor="#91A4B5" android:textSize="8sp" android:maxLines="1" />
        </LinearLayout>

        <TextView
            android:id="@+id/widget_today"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="اليوم"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:paddingStart="13dp"
            android:paddingEnd="13dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:background="@drawable/rased_schedule_day_chip_bg"
            android:maxLines="1" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:text=""
        android:background="#EDF1F4"
        android:layout_marginBottom="6dp" />

    <LinearLayout
        android:id="@+id/widget_periods_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:layoutDirection="rtl"
        android:gravity="center_vertical"
        android:baselineAligned="false">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layoutDirection="rtl"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:background="@drawable/rased_schedule_current_period_bg">

            <TextView android:layout_width="4dp" android:layout_height="match_parent" android:text=""
                android:background="#63AEEA" android:layout_marginEnd="11dp" />

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:orientation="vertical" android:gravity="center_vertical">
                <TextView android:id="@+id/widget_current_label" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="الحصة الآن" android:textColor="#2871B7" android:textSize="11sp" android:textStyle="bold" android:maxLines="1" />
                <TextView android:id="@+id/widget_current_class" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="-" android:textColor="#173B5F" android:textSize="22sp" android:textStyle="bold"
                    android:maxLines="1" android:ellipsize="end" android:layout_marginTop="4dp" />
                <TextView android:id="@+id/widget_current_subject" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="" android:textColor="#355E7C" android:textSize="11sp" android:textStyle="bold"
                    android:maxLines="1" android:ellipsize="end" android:layout_marginTop="2dp" />
                <TextView android:id="@+id/widget_current_time" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="" android:textColor="#2871B7" android:textSize="11sp" android:textStyle="bold"
                    android:maxLines="1" android:ellipsize="end" android:layoutDirection="ltr" android:textDirection="ltr"
                    android:gravity="end" android:layout_marginTop="5dp" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:text=""
            android:background="#DDE6ED"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="6dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layoutDirection="rtl"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:background="@drawable/rased_schedule_next_period_bg">

            <TextView android:layout_width="4dp" android:layout_height="match_parent" android:text=""
                android:background="#A7D2F3" android:layout_marginEnd="11dp" />

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:orientation="vertical" android:gravity="center_vertical">
                <TextView android:id="@+id/widget_next_label" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="القادمة" android:textColor="#637C90" android:textSize="11sp" android:textStyle="bold" android:maxLines="1" />
                <TextView android:id="@+id/widget_next_class" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="-" android:textColor="#24506F" android:textSize="22sp" android:textStyle="bold"
                    android:maxLines="1" android:ellipsize="end" android:layout_marginTop="4dp" />
                <TextView android:id="@+id/widget_next_subject" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="" android:textColor="#4D6D84" android:textSize="11sp" android:textStyle="bold"
                    android:maxLines="1" android:ellipsize="end" android:layout_marginTop="2dp" />
                <TextView android:id="@+id/widget_next_time" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="" android:textColor="#2F6287" android:textSize="11sp" android:textStyle="bold"
                    android:maxLines="1" android:ellipsize="end" android:layoutDirection="ltr" android:textDirection="ltr"
                    android:gravity="end" android:layout_marginTop="5dp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>


    <LinearLayout
        android:id="@+id/widget_status_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:background="@drawable/rased_schedule_status_bg">

        <TextView
            android:id="@+id/widget_status_icon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:gravity="center"
            android:text="✓"
            android:textColor="#FFFFFF"
            android:textSize="25sp"
            android:textStyle="bold"
            android:background="@drawable/rased_schedule_status_icon_bg" />

        <TextView
            android:id="@+id/widget_status_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="انتهت حصص اليوم"
            android:textColor="#2A78B9"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp" />

        <TextView
            android:id="@+id/widget_status_main"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="تم تنفيذ 4 حصص"
            android:textColor="#173B5F"
            android:textSize="19sp"
            android:textStyle="bold"
            android:gravity="center"
            android:maxLines="2"
            android:layout_marginTop="3dp" />

        <TextView
            android:id="@+id/widget_status_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="نتمنى لك يومًا موفقًا"
            android:textColor="#607D96"
            android:textSize="11sp"
            android:gravity="center"
            android:maxLines="2"
            android:layout_marginTop="3dp" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:text=""
        android:background="#EDF1F4"
        android:layout_marginTop="7dp" />

    <TextView
        android:id="@+id/widget_attendance_tip"
        android:layout_width="match_parent"
        android:layout_height="28dp"
        android:text="تذكير: تسجيل الحضور والغياب مبكرًا يختصر وقت المتابعة."
        android:textColor="#758B9D"
        android:textSize="9sp"
        android:gravity="center"
        android:maxLines="1"
        android:ellipsize="end" />
</LinearLayout>
