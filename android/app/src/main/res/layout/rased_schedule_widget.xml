<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="14dp"
    android:background="@drawable/rased_schedule_widget_bg"
    android:layoutDirection="rtl">

    <TextView
        android:id="@+id/widget_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="راصد - جدول الحصص"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/widget_today"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="الأحد"
        android:textColor="#DCE7FF"
        android:textSize="11sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center_vertical"
        android:layout_marginTop="8dp">

        <TextView
            android:id="@+id/widget_current_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="الحصة الآن"
            android:textColor="#93C5FD"
            android:textSize="10sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_current_class"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="7/1"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:maxLines="1" />

        <TextView
            android:id="@+id/widget_current_time"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="08:00 - 08:45"
            android:textColor="#DCE7FF"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/widget_next_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="القادمة"
            android:textColor="#FCD34D"
            android:textSize="10sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_next_class"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="8/2"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:maxLines="1" />

        <TextView
            android:id="@+id/widget_next_time"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="09:00 - 09:45"
            android:textColor="#DCE7FF"
            android:textSize="11sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/widget_updated"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="آخر تحديث من راصد"
        android:textColor="#BBD2FF"
        android:textSize="9sp" />
</LinearLayout>
