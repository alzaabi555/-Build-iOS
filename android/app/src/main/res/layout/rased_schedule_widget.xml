<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@drawable/rased_schedule_widget_bg"
    android:layoutDirection="rtl">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layoutDirection="rtl">

        <ImageView
            android:id="@+id/widget_logo"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:src="@mipmap/ic_launcher"
            android:contentDescription="راصد"
            android:scaleType="centerCrop" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="8dp"
            android:paddingEnd="8dp">

            <TextView
                android:id="@+id/widget_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="راصد"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="14sp"
                android:maxLines="1" />

            <TextView
                android:id="@+id/widget_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="جدول الحصص"
                android:textColor="#C7D2FE"
                android:textSize="9sp"
                android:maxLines="1" />
        </LinearLayout>

        <TextView
            android:id="@+id/widget_today"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="الأحد"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:textStyle="bold"
            android:background="@drawable/rased_schedule_day_chip_bg"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:layout_marginTop="9dp"
        android:layoutDirection="rtl">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1.08"
            android:orientation="vertical"
            android:padding="9dp"
            android:background="@drawable/rased_schedule_current_period_bg">

            <TextView
                android:id="@+id/widget_current_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="الحصة الآن"
                android:textColor="#DBEAFE"
                android:textSize="10sp"
                android:textStyle="bold"
                android:maxLines="1" />

            <TextView
                android:id="@+id/widget_current_class"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="7/1"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="18sp"
                android:maxLines="1" />

            <TextView
                android:id="@+id/widget_current_subject"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="المادة"
                android:textColor="#E0F2FE"
                android:textSize="9sp"
                android:maxLines="1" />

            <TextView
                android:id="@+id/widget_current_time"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="08:00 - 08:45"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:maxLines="1" />
        </LinearLayout>

        <Space
            android:layout_width="8dp"
            android:layout_height="match_parent" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0.92"
            android:orientation="vertical"
            android:padding="9dp"
            android:background="@drawable/rased_schedule_next_period_bg">

            <TextView
                android:id="@+id/widget_next_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="القادمة"
                android:textColor="#FDE68A"
                android:textSize="10sp"
                android:textStyle="bold"
                android:maxLines="1" />

            <TextView
                android:id="@+id/widget_next_class"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="8/2"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="15sp"
                android:maxLines="1" />

            <TextView
                android:id="@+id/widget_next_subject"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="المادة"
                android:textColor="#E5E7EB"
                android:textSize="9sp"
                android:maxLines="1" />

            <TextView
                android:id="@+id/widget_next_time"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="09:00 - 09:45"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold"
                android:maxLines="1" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/widget_updated"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="آخر تحديث من راصد"
        android:textColor="#BFDBFE"
        android:textSize="8sp"
        android:maxLines="1" />
</LinearLayout>
